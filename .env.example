# Server
PORT=8000
NODE_ENV=development

# CORS (comma-separated for multiple origins)
CORS_ORIGIN=http://localhost:5173

# Auth
# Keep disabled in production unless you explicitly want open self-registration
ALLOW_PUBLIC_REGISTER=false

# JWT (REQUIRED - server will not start without this)
JWT_SECRET=---

# MongoDB (REQUIRED)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/contago
# Optional, if you want to override DB from URI
# MONGODB_DB=contago

# Admin seed (optional - set to auto-create admin on startup)
ADMIN_EMAIL=info@contago.com.co
ADMIN_PASSWORD=change-this-password
ADMIN_NAME=ContaGO Admin

# Puppeteer
# Only set PUPPETEER_EXECUTABLE_PATH if you installed Chromium yourself
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
# Optional: cache dir for puppeteer downloads (Render default below)
# PUPPETEER_CACHE_DIR=/opt/render/.cache/puppeteer

# DIAN safety limits
DIAN_MAX_DOCUMENTS=300

# DIAN SOAP integration
# hab = habilitación, prod = producción
DIAN_ENVIRONMENT=hab
# Timeout SOAP en milisegundos
DIAN_SOAP_TIMEOUT_MS=45000

# Opcional para script de prueba rápida (npm run test:dian)
# DIAN_TEST_ENVIRONMENT=hab
# DIAN_TEST_NIT=900000000
# DIAN_TEST_P12_PATH=/secure/certs/empresa.p12
# DIAN_TEST_P12_PASSWORD=super-secreta
# DIAN_TEST_TRACK_ID=CUFE_O_TRACKID_DE_PRUEBA

# Google Drive Integration (for DIAN Excel Exporter)
# Get these from: https://console.cloud.google.com
# Create OAuth 2.0 credentials -> Web application
# Add redirect URI: http://localhost:8000/auth/google/callback (dev)
#                   https://your-api-domain/auth/google/callback (prod)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Encryption key for storing Google tokens (32 bytes hex = 64 chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GOOGLE_TOKEN_ENCRYPTION_KEY=generate-a-64-char-hex-string-here

# Public API URL (used for OAuth callback)
API_URL=http://localhost:8000

# Siigo integration
SIIGO_API_BASE_URL=https://api.siigo.com
# Optional (default: SentiidoAI)
SIIGO_PARTNER_ID=SentiidoAI
SIIGO_USERNAME=your-siigo-username
SIIGO_ACCESS_KEY=your-siigo-access-key

# Internal API key for GPT/automation access to /integrations/siigo/*
GPT_INTERNAL_API_KEY=your-fixed-internal-api-key
