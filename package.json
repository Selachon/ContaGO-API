{
  "name": "contago-api",
  "version": "1.0.0",
  "description": "ContaGO Backend API - Express + TypeScript",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test:causation": "tsx --test src/services/causationService.test.ts src/routes/causation.test.ts",
    "test:siigo": "tsx --test src/routes/siigo.test.ts",
    "test:dian": "tsx scripts/test-dian.ts",
    "migrate:sqlite-mongo": "tsx scripts/migrateSqliteToMongo.ts",
    "template:dian-excel": "node scripts/generateDianExcelTemplate.mjs",
    "postinstall": "node scripts/installPuppeteer.mjs"
  },
  "keywords": [
    "contago",
    "dian",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@types/archiver": "^6.0.2",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/helmet": "^0.0.48",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.7.4",
    "@types/node-forge": "^1.3.14",
    "@types/uuid": "^10.0.0",
    "@types/xml2js": "^0.4.14",
    "archiver": "^4.0.2",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^11.3.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.1.1",
    "express": "^4.21.0",
    "fast-xml-parser": "^5.4.1",
    "googleapis": "^144.0.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "mongodb": "^7.1.0",
    "multer": "^2.1.1",
    "node-forge": "^1.4.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "puppeteer": "^23.5.0",
    "soap": "^1.8.0",
    "uuid": "^10.0.0",
    "xml-crypto": "^6.1.2",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=20"
  }
}
